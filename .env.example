# =========================
# Nara API Keys
# Paste your keys here
# =========================

DISCORD_TOKEN=
GEMINI_API_KEY=

# =========================
# Discord Settings
# =========================

# These can stay blank. Nara's channel picker GUI can select them at startup.
DEFAULT_VOICE_CHANNEL_ID=
DEFAULT_TEXT_CHANNEL_ID=
GUILD_ID=

# =========================
# STT Settings
# =========================

STT_ENGINE=local_whisper
STT_MODEL_SIZE=tiny
STT_ALLOWED_LANGUAGES=id,en
STT_DEFAULT_LANGUAGE=id
STT_FORCE_LANGUAGE_WHITELIST=true
STT_REJECT_OTHER_LANGUAGES=true
STT_CHUNK_SECONDS=25
STT_COMPUTE_MODE=cpu
STT_THREADS=4

# =========================
# Output Settings
# =========================

OUTPUT_LANGUAGE=mixed
SAVE_RAW_AUDIO=true
SAVE_AUDIO_CHUNKS=true

# =========================
# Speaker Contact Settings
# =========================

CONTACTS_FILE=data/contacts/speaker_contacts.json

# =========================
# Obsidian Vault Settings
# =========================

OBSIDIAN_VAULT_PATH=obsidian_vault
OBSIDIAN_COPY_AUDIO=false
